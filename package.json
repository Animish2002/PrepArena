{
  "name": "preParena",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "deploy:api": "npm run deploy --workspace=apps/api",
    "deploy:web": "npm run build --workspace=apps/web && wrangler pages deploy apps/web/dist --project-name preparena-web --commit-dirty=true"
  }
}
